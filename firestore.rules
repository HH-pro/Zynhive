rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null;
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /team/{memberId} {
      allow read: if true;
      // Member portal needs update access to save email and apply overdue
      // score adjustments. Create/delete stay admin-only.
      allow update: if true;
      allow create, delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read, write: if isAdmin();
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /client_updates/{updateId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /update_feedback/{feedbackId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tasks/{taskId} {
      // Member portal needs to read assigned tasks and write status,
      // checklist progress, completion reports, and penaltyApplied.
      allow read: if true;
      allow update: if true;
      allow create, delete: if isAdmin();
    }

    match /pending_reviews/{reviewId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /routines/{routineId} {
      // Members read their assigned routines and toggle items / submit reports.
      // Admin creates and removes routines.
      allow read, update: if true;
      allow create, delete: if isAdmin();
    }

    match /ideas/{ideaId} {
      // Members submit ideas from the portal. Admin reviews, comments, deletes.
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }

    match /member_messages/{messageId} {
      // Admin sends messages from the dashboard; member portal reads them
      // and flips `read: true` when opened.
      allow read, update: if true;
      allow create, delete: if isAdmin();
    }

    match /activity_log/{logId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
